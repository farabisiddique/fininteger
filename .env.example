# FastAPI Configuration
# DEBUG=True also enables auto-reload when starting via `python main.py`
DEBUG=False

# Database
DATABASE_URL=sqlite:///./forecast.db

# Logging (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# User tour + disclaimer: 1 = show to ALL users every visit (testing), 0 = first-time visitors only
SHOW_TOUR_TO_ALL=0
